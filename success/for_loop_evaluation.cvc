// For-loop check should be evaluated once!
// Expected output: 000001
#include "civic.h"

int a = 0;

int foo() {
    a = a + 1;
    return 5;
}

export int main() {
    for (int i = 0, foo()) {
        printInt(0);
    }

    printInt(a);

    if (a != 1) {
        printInt(a);
        return 1;
    }

    return 0;
}

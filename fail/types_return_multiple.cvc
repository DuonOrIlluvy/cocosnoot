// Should give a type checking error because a int function cannot return float.

int fun(int a) {

    if (a > 5) {
        // error: Wrong return type, expected int but got float
        return 5.0;
    } else {
        // error: Wrong return type, expected int but got float
        return 8.0;
    }

    return 5;
}

export int main() {
    return 0;
}

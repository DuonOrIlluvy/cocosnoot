// Should produce a type checking error because funcalls also have a type.

#include "civic.h"

float kaas() {
    return 6.0;
}

export int main() {
    int a = 0;
    // error: Left and right operand of binary operator have non matching types,
    // left operand has type int and right operand has type float
    a = a + kaas();
    return 0;
}
